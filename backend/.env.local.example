# .env.local.example
# Copy to .env.local and fill in real values.
# NEVER commit .env.local — it is in .gitignore.

# ── App ──
ENV=development
DEBUG=true
SECRET_KEY=change-me-in-development

# ── Database (Supabase) ──
# Option A: full connection string
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project>.supabase.co:5432/postgres

# Option B: individual vars (config.py will build the URL)
SUPABASE_DB_HOST=db.<project-ref>.supabase.co
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_DB_USER=postgres
SUPABASE_DB_NAME=postgres
SUPABASE_DB_PORT=5432

# ── Supabase Auth + Storage ──
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret          # Settings → API → JWT Secret in Supabase dashboard
SUPABASE_STORAGE_BUCKET=docloop-documents

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
REDIS_ARQ_DB=1

# ── CORS (comma-separated) ──
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Email (Resend) ──
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@docloop.app

# ── SMS (Twilio) ──
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ── Payments (Stripe) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# ── AI (OpenAI) ──
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
